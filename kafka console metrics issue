console.yaml

---
apiVersion: console.streamshub.github.com/v1alpha1
kind: Console
metadata:
  name: dev-console
  namespace: dev-kafka

spec:
  hostname: dev-kafkaconsole.apps.dev.sbiepay.sbi

  kafkaClusters:
    - name: dev-kafka-cluster
      namespace: dev-kafka
      listener: plain

      properties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      adminProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: '30000'
          - name: default.api.timeout.ms
            value: '30000'

      consumerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: '30000'

      producerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: '30000'

  metricsSources:
    # - name: k8s
    #   type: openshift-monitoring
      #url: "https://thanos-querier-openshift-monitoring.apps.dev.sbiepay.sbi"
    - name: "kafka-metrics"
      type: "openshift-monitoring"
      url: {{ .Values.console.metrics.prometheus.url | quote }}





values.yaml

console:
  metrics:
    prometheus:
      url: http://thanos-querier.openshift-monitoring.svc.cluster.local:9091
