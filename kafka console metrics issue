oc patch podmonitor kafka-resources-metrics -n dev-kafka --type='json' \
  -p='[{"op": "replace", "path": "/spec/namespaceSelector/matchNames/0", "value": "dev-kafka"}]'

# Verify
oc get podmonitor kafka-resources-metrics -n dev-kafka -o jsonpath='{.spec.namespaceSelector}'



# Add label so user-workload Prometheus scrapes this namespace
oc label namespace dev-kafka openshift.io/user-monitoring=true --overwrite

# Verify
oc get namespace dev-kafka --show-labels







# Check all 4 environments namespace selector
for ns in dev-kafka sit-kafka uat-kafka int-kafka; do
  echo "=== $ns ==="
  oc get podmonitor kafka-resources-metrics -n $ns \
    -o jsonpath='{.spec.namespaceSelector}' 2>/dev/null || echo "NOT FOUND"
  echo ""
done
