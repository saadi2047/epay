# 1. Confirm what Prometheus namespace is being used
oc get prometheus -A
oc get prometheusrule -n dev-kafka

# 2. Check what namespace Prometheus is watching
oc get prometheus -n openshift-monitoring -o yaml | grep -A 10 "namespaceSelector\|ruleNamespaceSelector"

# 3. Check the console deployment env vars fully
oc get deployment dev-console-console-deployment -n dev-kafka -o yaml | grep -A 2 "env\|PROMETHEUS\|METRIC\|BOOTSTRAP\|KAFKA"

# 4. Check the console ConfigMap for its config
oc get configmap -n dev-kafka | grep console
oc get configmap <console-configmap-name> -n dev-kafka -o yaml

# 5. Verify Prometheus can reach dev-kafka namespace
oc get rolebinding -n dev-kafka | grep prometheus
oc get clusterrolebinding | grep prometheus

# 6. Check if broker port is named correctly (PodMonitor expects tcp-prometheus)
oc get pod dev-kafka-cluster-broker-0 -n dev-kafka -o yaml | grep -A 5 "ports:"

# 7. Verify actual kafka metrics ARE present (not just java_lang)
oc exec -n dev-kafka dev-kafka-cluster-broker-0 -- curl -s localhost:9404/metrics | grep "^kafka_" | head -20
