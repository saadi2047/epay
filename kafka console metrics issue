console.yaml

---
apiVersion: v1
kind: Secret
metadata:
  name: dev-console-console-secret
  namespace: dev-kafka
type: Opaque
stringData:
  console-config.yaml: |
    kubernetes:
      enabled: true
    metricsSources:
      - name: kafka-metrics
        type: openshift-monitoring
        url: {{ .Values.console.metrics.prometheus.url | quote }}
    kafka:
      clusters:
        - name: dev-kafka-cluster
          namespace: dev-kafka
          listener: plain
          properties:
            security.protocol: PLAINTEXT
            bootstrap.servers: dev-kafka-cluster-kafka-bootstrap.dev-kafka.svc:9092




values.yaml

console:
  metrics:
    prometheus:
      url: http://thanos-querier.openshift-monitoring.svc.cluster.local:9091
