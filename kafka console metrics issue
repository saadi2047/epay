metricsSources:
  - name: kafka-metrics
    type: openshift-monitoring
    url: https://thanos-querier-openshift-monitoring.apps.dev.sbiepay.sbi
    authentication:
      type: bearer
      bearer:
        token:
          from: serviceAccount


oc get secret dev-console-console-secret -n dev-kafka \
-o jsonpath='{.data.console-config\.yaml}' | base64 -d | grep url


oc logs -n dev-kafka deployment/dev-console-console-deployment --since=2m
oc rollout restart deployment/dev-console-console-deployment -n dev-kafka

oc logs -n dev-kafka deployment/dev-console-console-deployment | grep -i prometheus

