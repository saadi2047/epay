# 1. See ALL broker ports (not just first 5 lines)
oc get pod dev-kafka-cluster-broker-0 -n dev-kafka -o yaml | grep -A 3 "name: tcp"

# 2. Find where console-config.yaml is coming from
oc get deployment dev-console-console-deployment -n dev-kafka -o yaml | grep -A 5 "volume\|mount\|secret\|configmap"

# 3. Check if console config is in a secret
oc get secret -n dev-kafka | grep console

# 4. Check user-workload monitoring is enabled and can scrape dev-kafka
oc get configmap cluster-monitoring-config -n openshift-monitoring -o yaml

# 5. Check if dev-kafka namespace has user-workload monitoring label
oc get namespace dev-kafka -o yaml | grep -i "label\|monitor"

# 6. Check where Prometheus user-workload is scraping
oc get prometheus user-workload -n openshift-user-workload-monitoring -o yaml | grep -A 10 "namespaceSelector\|serviceMonitor\|podMonitor"

# 7. Check the console deployment volumes in detail
oc describe deployment dev-console-console-deployment -n dev-kafka | grep -A 20 "Volumes:\|Mounts:"




