---
kubernetes:
  enabled: true
security:
  subjects: []
  roles: []
  audit: []
  oidc: null
metricsSources:
- name: "kafka-metrics"
  type: "openshift-monitoring"
  url: "http://thanos-querier.openshift-monitoring.svc.cluster.local:9091"
schemaRegistries: []
kafka:
  clusters:
  - name: "dev-kafka-cluster"
    namespace: "dev-kafka"
    listener: "plain"
    security:
      subjects: []
      roles: []
      audit: []
    properties:
      security.protocol: "PLAINTEXT"
      bootstrap.servers: "dev-kafka-cluster-kafka-bootstrap.dev-kafka.svc:9092"
    adminProperties:
      security.protocol: "PLAINTEXT"
      request.timeout.ms: "30000"
      default.api.timeout.ms: "30000"
