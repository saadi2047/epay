# Step 2 - patch the secret
oc patch secret dev-console-console-secret -n dev-kafka \
  --type='json' \
  -p="[{\"op\": \"replace\", \"path\": \"/data/console-config.yaml\", \"value\": \"$(base64 -w 0 /tmp/console-config.yaml)\"}]"

# Step 3 - verify secret updated
oc get secret dev-console-console-secret -n dev-kafka \
  -o jsonpath='{.data.console-config\.yaml}' | base64 -d | grep url

# Step 4 - restart console
oc rollout restart deployment/dev-console-console-deployment -n dev-kafka

# Step 5 - watch it come up
oc rollout status deployment/dev-console-console-deployment -n dev-kafka
