# 1. Find what URL the console is actually trying to hit
oc get secret dev-console-console-secret -n dev-kafka \
  -o jsonpath='{.data.console-config\.yaml}' | base64 -d | grep -A5 metrics

# 2. Get the OpenShift CA certificate
oc get configmap kube-root-ca.crt -n dev-kafka -o yaml | grep -c "BEGIN CERTIFICATE"

# 3. Check if OCP CA configmap exists
oc get configmap openshift-service-ca.crt -n dev-kafka



apiVersion: console.streamshub.github.com/v1alpha1
kind: Console
metadata:
  name: dev-console
  namespace: dev-kafka

spec:
  hostname: dev-kafkaconsole.apps.dev.sbiepay.sbi

  metricsSources:
    - name: kafka-metrics
      type: openshift-monitoring
      trustStore:
        type: PEM
        content:
          valueFrom:
            configMapKeyRef:
              name: openshift-service-ca.crt
              key: service-ca.crt

  kafkaClusters:
    - name: dev-kafka-cluster
      namespace: dev-kafka
      listener: plain
      metricsSource: kafka-metrics

      properties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      adminProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"
          - name: default.api.timeout.ms
            value: "30000"

      consumerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"

      producerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"



oc logs -n dev-kafka deployment/dev-console-console-deployment --since=2m | grep -i "metric\|ssl\|error"
