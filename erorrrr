apiVersion: console.streamshub.github.com/v1alpha1
kind: Console
metadata:
  name: dev-console
  namespace: dev-kafka

spec:
  hostname: dev-kafkaconsole.apps.dev.sbiepay.sbi

  metricsSources:
    - name: kafka-metrics
      type: openshift-monitoring
      trustStore:
        type: PEM
        content:
          valueFrom:
            configMapKeyRef:
              name: kube-root-ca.crt
              key: ca.crt

  kafkaClusters:
    - name: dev-kafka-cluster
      namespace: dev-kafka
      listener: plain
      metricsSource: kafka-metrics

      properties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: connections.max.idle.ms
            value: "540000"
          - name: reconnect.backoff.ms
            value: "1000"
          - name: reconnect.backoff.max.ms
            value: "10000"

      adminProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"
          - name: default.api.timeout.ms
            value: "30000"
          - name: connections.max.idle.ms
            value: "540000"
          - name: reconnect.backoff.ms
            value: "1000"
          - name: reconnect.backoff.max.ms
            value: "10000"

      consumerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"
          - name: connections.max.idle.ms
            value: "540000"
          - name: reconnect.backoff.ms
            value: "1000"
          - name: reconnect.backoff.max.ms
            value: "10000"

      producerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"
          - name: connections.max.idle.ms
            value: "540000"
          - name: reconnect.backoff.ms
            value: "1000"
          - name: reconnect.backoff.max.ms
            value: "10000"
