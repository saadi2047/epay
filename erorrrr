apiVersion: console.streamshub.github.com/v1alpha1
kind: Console
metadata:
  name: dev-console
  namespace: dev-kafka

spec:
  hostname: dev-kafkaconsole.apps.dev.sbiepay.sbi

  metricsSources:
    - name: kafka-metrics
      type: openshift-monitoring

  kafkaClusters:
    - name: dev-kafka-cluster
      namespace: dev-kafka
      listener: plain
      metricsSource: kafka-metrics

      properties:
        values:
          - name: security.protocol
            value: PLAINTEXT

      adminProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"
          - name: default.api.timeout.ms
            value: "30000"

      consumerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"

      producerProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"





# 1. Confirm the CR is updated
oc get consoles.console.streamshub.github.com dev-console -n dev-kafka -o yaml | grep -A3 metricsSource

# 2. Check console logs - should NOT see "Prometheus URL is not configured" anymore
oc logs -n dev-kafka deployment/dev-console-console-deployment --since=2m | grep -i metric
