# 1. Check if brokers are restarting / have recent restarts
oc get pods -n dev-kafka | grep broker

# 2. Check broker restart count and uptime
oc get pods -n dev-kafka -o wide | grep broker

# 3. Check if Kafka Connect is crashing (it was showing high restarts earlier)
oc get pods -n dev-kafka | grep connect

# 4. Check if there are any network policies blocking console → broker traffic
oc get networkpolicy -n dev-kafka




adminProperties:
        values:
          - name: security.protocol
            value: PLAINTEXT
          - name: request.timeout.ms
            value: "30000"
          - name: default.api.timeout.ms
            value: "30000"
          - name: connections.max.idle.ms
            value: "540000"
          - name: reconnect.backoff.ms
            value: "1000"
          - name: reconnect.backoff.max.ms
            value: "10000"
